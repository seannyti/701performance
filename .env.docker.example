# Copy this to .env and fill in your production values
# NEVER commit the .env file to git
# Run: cp .env.docker.example .env

# ─── Database ────────────────────────────────────────────────────────────────
# Your Akamai managed MySQL connection string
DB_CONNECTION_STRING=Server=your-host.akamaidb.net;Port=15921;Database=defaultdb;Uid=akmadmin;Pwd=YOUR_DB_PASSWORD_HERE;SslMode=Required;

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=CHANGE-THIS-TO-A-STRONG-RANDOM-SECRET-AT-LEAST-32-CHARS-LONG-FOR-PRODUCTION!
