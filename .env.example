# ASP.NET environment — Production for prod, Development locally if you want Swagger
ASPNETCORE_ENVIRONMENT=Production

# Database (db service in docker-compose)
DB_NAME=performancepower
DB_USER=ppuser
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# JWT — secret must be 32+ chars
JWT_SECRET=change-me-to-a-32-plus-character-secret
JWT_ISSUER=performancepower-api
JWT_AUDIENCE=performancepower-apps

# Public URL of the site (used for CORS allowlist + email link generation)
# Local: http://localhost
# Prod:  https://yourdomain.com
SITE_URL=http://localhost

# Anthropic API key (used by inventory spec-sheet auto-fill)
ANTHROPIC_API_KEY=sk-ant-api03-...
