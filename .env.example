# Copy this file to .env.local and set your local dev values.
# NEVER commit .env.local to git.
# Run: cp .env.local.example .env.local

# ─── Local MySQL ──────────────────────────────────────────────────────────────
LOCAL_DB_ROOT_PASSWORD=change-me-root
LOCAL_DB_PASSWORD=change-me-appuser

# ─── JWT signing key (local dev only) ────────────────────────────────────────
# Must be at least 32 characters
LOCAL_JWT_SECRET=change-me-local-jwt-secret-at-least-32-chars!

# --- Swagger UI (local dev only) -------------------------------------------
# Set to true to enable Swagger UI when ASPNETCORE_ENVIRONMENT=Development
SWAGGER_ENABLED=true
